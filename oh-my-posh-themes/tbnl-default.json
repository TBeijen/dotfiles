{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "aws_orange": "#ff9900",
    "azure_blue": "#0078d4",
    "azure_blue_light": "#0a95ff",
    "bg_grey": "#202237",
    "bg_grey_light": "#5b64a4",
    "black": "#262B44",
    "blue": "#4B95E9",
    "cyan": "#00ffd7",
    "dark_slate_grey": "#87d7d7",
    "gold": "#afaf00",
    "green": "#59C9A5",
    "k8s_blue": "#326CE5",
    "nodejs_green": "#84ba64",
    "orange": "#F07623",
    "red": "#D81E5B",
    "red_bright": "#f00a55",
    "white": "#E0DEF4",
    "yellow": "#F3AE35"
  },
  "secondary_prompt": {
    "template": "<,p:bg_grey> ></><p:bg_grey,transparent>\ue0b0</> ",
    "foreground": "p:white",
    "background": "transparent"
  },
  "upgrade": {
    "source": "cdn",
    "interval": "168h",
    "auto": false,
    "notice": false
  },
  "console_title_template": "{{ .Shell }} in {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "options": {
            "always_enabled": true
          },
          "trailing_diamond": "\ue0b0",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }}",
          "foreground": "p:white",
          "background": "p:bg_grey_light",
          "type": "status",
          "style": "diamond",
          "background_templates": [
            "{{ if gt .Code 0 }}p:red{{ end }}"
          ]
        },
        {
          "options": {
            "time_format": "15:04 | Mon"
          },
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\uf017 {{ .CurrentDate | date .Format }} ",
          "foreground": "p:white",
          "background": "p:bg_grey",
          "type": "time",
          "style": "diamond"
        },
        {
          "options": {
            "display_default": false
          },
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\uf0ef {{.Profile}}",
          "foreground": "p:aws_orange",
          "background": "p:bg_grey",
          "type": "aws",
          "style": "diamond"
        },
        {
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\uebd8 {{.Name}}",
          "foreground": "p:azure_blue_light",
          "background": "p:bg_grey",
          "type": "az",
          "style": "diamond"
        },
        {
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\ue81d {{.Context}}{{if .Namespace}} :: {{.Namespace}}{{end}} ",
          "foreground": "p:k8s_blue",
          "background": "p:bg_grey",
          "type": "kubectl",
          "style": "diamond"
        },
        {
          "options": {
            "display_default": false,
            "display_mode": "environment",
            "fetch_version": true,
            "fetch_virtual_env": true
          },
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{.Venv}}{{ else }}{{ .Full }}{{ end }}{{ end }} ",
          "foreground": "p:gold",
          "background": "p:bg_grey",
          "type": "python",
          "style": "diamond"
        },
        {
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "\ued0d {{ .Full }} ",
          "foreground": "p:nodejs_green",
          "background": "p:bg_grey",
          "type": "node",
          "style": "diamond"
        },
        {
          "options": {
            "style": "folder"
          },
          "template": "\uea83 {{ path .Path .Location }} ",
          "foreground": "p:cyan",
          "powerline_symbol": "\ue0b0",
          "background": "p:bg_grey",
          "type": "path",
          "style": "powerline"
        },
        {
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "leading_diamond": "<transparent,p:bg_grey>\ue0b0</>",
          "trailing_diamond": "<transparent>\ue0bd</>",
          "template": "{{ if .UpstreamURL }}{{ url .UpstreamIcon .UpstreamURL }} {{ end }}{{ substr 0 3 .HEAD }} {{ substr 3 25 .HEAD }} ",
          "foreground": "p:dark_slate_grey",
          "powerline_symbol": "\ue0b0",
          "background": "p:bg_grey",
          "type": "git",
          "style": "diamond"
        },
        {
          "options": {
            "branch_template": "{{ trunc 25 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "trailing_diamond": "\ue0b0",
          "template": "{{if .BranchStatus }}{{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }} ",
          "foreground": "p:dark_slate_grey",
          "powerline_symbol": "\ue0b0",
          "background": "p:bg_grey",
          "type": "git",
          "style": "diamond",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red_bright{{ end }}",
            "{{ if gt .Ahead 0 }}#8980b3{{ end }}",
            "{{ if gt .Behind 0 }}#7A306C{{ end }}"
          ]
        },
        {
          "leading_diamond": "<transparent,p:red_bright>\ue0b0</>",
          "trailing_diamond": "\ue0b0",
          "template": "{{ if or (and (.Segments.Contains \"Kubectl\") (matchP \"prod\" (lower .Segments.Kubectl.Cluster)) (not (matchP \"-non-prod\" (lower .Segments.Kubectl.Cluster))) ) (and (.Segments.Contains \"Aws\") (matchP \"prod\" (lower .Segments.Aws.Profile))) }} \uf12a\uf12a\uf12a {{ else }}{{ end }}",
          "foreground": "p:white",
          "background": "p:red_bright",
          "type": "text",
          "style": "diamond"
        }
      ]
    }
  ],
  "version": 4,
  "final_space": true
}